{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/docs/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/build"],
      "options": {
        "cwd": "apps/docs",
        "command": "docusaurus build"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "cwd": "apps/docs",
        "command": "docusaurus start --host 0.0.0.0"
      }
    },
    "serve-static": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "continuous": true,
      "options": {
        "cwd": "apps/docs",
        "command": "docusaurus serve --host 0.0.0.0"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/docs",
        "command": "tsc --noEmit"
      }
    },
    "clear": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/docs",
        "command": "docusaurus clear"
      }
    }
  }
}
